{
  "name": "template-typescript-lib",
  "version": "0.0.0-dripip",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/jasonkuhrt/template-typescript-lib.git"
  },
  "author": {
    "name": "Jason Kuhrt",
    "url": "https://kuhrt.me"
  },
  "keywords": [
    "foo",
    "bar",
    "qux"
  ],
  "bugs": {
    "url": "https://github.com/jasonkuhrt/template-typescript-lib/issues"
  },
  "packageManager": "pnpm@10.8.0",
  "license": "MIT",
  "type": "module",
  "files": [
    "src",
    "build",
    "README.md"
  ],
  "exports": {
    ".": "./build/exports/index.js"
  },
  "scripts": {
    "bootstrap": "tsx scripts/bootstrap.ts",
    "build:toc": "markdown-toc README.md -i --maxdepth 4 && dprint fmt README.md",
    "build:watch:emit": "pnpm build --noCheck --watch",
    "build:watch": "pnpm build --watch",
    "build:emit": "pnpm build --noEmit",
    "build": "tsgo --build tsconfig.build.json",
    "build:clean": "tsgo --build --clean && rm -rf build",
    "prebuild": "pnpm pnpm build:clean",
    "test": "pnpm test:unit",
    "test:unit": "vitest --root src",
    "prepack": "pnpm build",
    "fix": "pnpm fix:format && pnpm fix:lint",
    "fix:format": "dprint fmt",
    "fix:lint": "eslint . --fix",
    "check": "pnpm check:format && pnpm check:lint && pnpm check:types && pnpm check:package",
    "check:format": "dprint check",
    "check:lint": "eslint . --max-warnings 0",
    "check:types": "tsgo",
    "check:package": "publint run --strict"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@tsconfig/node22": "^22.0.5",
    "@tsconfig/recommended": "1.0.13",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.0.3",
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "dripip": "0.10.0",
    "eslint": "9.39.2",
    "eslint-plugin-only-warn": "1.1.0",
    "eslint-plugin-tsdoc": "0.5.0",
    "execa": "9.6.1",
    "fast-glob": "3.3.3",
    "floggy": "0.3.5",
    "fs-jetpack": "5.1.0",
    "inquirer": "13.1.0",
    "markdown-toc": "1.2.0",
    "publint": "^0.3.16",
    "tsx": "4.21.0",
    "@typescript/native-preview": "^7.0.0-dev.20251215.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "4.0.16"
  },
  "dependencies": {
    "@wollybeard/kit": "^0.108.0",
    "effect": "^3.19.12"
  }
}
