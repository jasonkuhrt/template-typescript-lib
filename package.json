{
  "name": "template-typescript-lib",
  "version": "0.0.0-dripip",
  "keywords": [
    "bar",
    "foo",
    "qux"
  ],
  "bugs": {
    "url": "https://github.com/jasonkuhrt/template-typescript-lib/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Jason Kuhrt",
    "url": "https://kuhrt.me"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/jasonkuhrt/template-typescript-lib.git"
  },
  "files": [
    "build",
    "README.md",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#lib/*": "./src/lib/*.ts"
  },
  "exports": {
    ".": "./build/exports/index.js"
  },
  "scripts": {
    "bootstrap": "bun scripts/bootstrap.ts",
    "build:toc": "markdown-toc README.md -i --maxdepth 4 && oxfmt --write README.md",
    "build:watch:emit": "bun run build --noCheck --watch",
    "build:watch": "bun run build --watch",
    "build:emit": "bun run build --noEmit",
    "build": "tsgo --build tsconfig.build.json",
    "build:clean": "tsgo --build --clean && rm -rf build",
    "prebuild": "bun run build:clean",
    "test": "bun run test:unit",
    "test:unit": "bun test src",
    "test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir=coverage src",
    "prepack": "bun run build && bun scripts/prepack-imports.ts",
    "postpack": "bun scripts/prepack-imports.ts --restore",
    "fix": "bun run fix:format && bun run fix:lint",
    "fix:format": "oxfmt --write",
    "fix:lint": "oxlint --type-aware --fix-dangerously --deny-warnings",
    "check": "bun run check:format && bun run check:lint && bun run check:types && bun run test && bun run check:cov && bun run check:package && bun run check:exports && bun run check:ci",
    "check:format": "oxfmt --check",
    "check:lint": "oxlint --type-aware --deny-warnings",
    "check:types": "tsgo",
    "check:cov": "bun run test:coverage && bun scripts/check-coverage.ts coverage/lcov.info 95",
    "check:package": "publint run --strict",
    "check:exports": "attw --pack . --profile esm-only",
    "check:ci": "actionlint",
    "hooks:install": "git-hooks install",
    "pre-commit": "lint-staged --relative"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@effect/platform": "^0.94.5",
    "@effect/platform-node": "^0.104.1",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "2.0.8",
    "@types/bun": "^1.3.10",
    "@types/node": "25.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260306.1",
    "dripip": "0.10.0",
    "effect": "^3.19.19",
    "fast-glob": "3.3.3",
    "floggy": "0.3.5",
    "inquirer": "13.3.0",
    "lint-staged": "^16.4.0",
    "markdown-toc": "1.2.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "publint": "^0.3.18",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "effect": "^3.19.19"
  }
}
