{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/refs/heads/main/npm/oxlint/configuration_schema.json",
  "plugins": ["import", "promise", "typescript"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "eslint/no-unused-vars": "off",
    "eslint/no-unused-expressions": "off",
    "eslint/eqeqeq": "error",
    "eslint/no-var": "error",
    "eslint/array-callback-return": "error",
    "eslint/no-throw-literal": "error",
    "eslint-plugin-import/no-unassigned-import": "off",
    "eslint-plugin-promise/no-new-statics": "warn",
    "eslint-plugin-promise/no-callback-in-promise": "warn",
    "eslint-plugin-promise/prefer-await-to-then": "warn",
    "unicorn/prefer-node-protocol": "error",
    "unicorn/error-message": "error",
    "oxc/no-accumulating-spread": "warn",

    "typescript/no-explicit-any": "warn",
    "typescript/no-unsafe-type-assertion": "warn",
    "typescript/no-unnecessary-type-assertion": "warn",
    "typescript/no-floating-promises": "error",
    "typescript/no-misused-promises": "error",
    "typescript/await-thenable": "error",
    "typescript/no-unsafe-argument": "error",
    "typescript/no-unsafe-assignment": "error",
    "typescript/no-unsafe-call": "error",
    "typescript/no-unsafe-member-access": "error",
    "typescript/no-unsafe-return": "error",
    "typescript/no-for-in-array": "error",
    "typescript/no-array-delete": "error",
    "typescript/no-implied-eval": "error",
    "typescript/no-deprecated": "warn",
    "typescript/no-base-to-string": "warn",
    "typescript/no-confusing-void-expression": "warn",
    "typescript/prefer-includes": "warn",
    "typescript/prefer-nullish-coalescing": "warn",
    "typescript/prefer-optional-chain": "warn",
    "typescript/restrict-plus-operands": "warn",
    "typescript/unbound-method": "warn",
    "typescript/switch-exhaustiveness-check": "error",
    "typescript/consistent-type-imports": "error",
    "typescript/return-await": "warn",
    "typescript/only-throw-error": "error",
    "typescript/no-non-null-assertion": "warn",
    "typescript/no-import-type-side-effects": "warn",
    "typescript/no-unnecessary-condition": "warn",
    "typescript/ban-ts-comment": "warn"
  },
  "overrides": [
    {
      "files": ["src/**/*.ts", "src/**/*.tsx", "scripts/**/*.ts", "scripts/**/*.tsx"],
      "rules": {
        "import/no-nodejs-modules": "error",
        "eslint/no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "execa"
              },
              {
                "name": "fs-jetpack"
              },
              {
                "name": "lodash"
              },
              {
                "name": "lodash-es"
              },
              {
                "name": "ramda"
              },
              {
                "name": "axios"
              },
              {
                "name": "got"
              },
              {
                "name": "node-fetch"
              },
              {
                "name": "cross-fetch"
              },
              {
                "name": "ky"
              },
              {
                "name": "p-map"
              },
              {
                "name": "p-limit"
              },
              {
                "name": "p-queue"
              }
            ],
            "patterns": ["lodash/*", "lodash-es/*"]
          }
        ]
      }
    },
    {
      "files": ["src/**/*.test.ts", "src/**/*.spec.ts", "src/**/*.test.tsx", "src/**/*.spec.tsx"],
      "rules": {
        "import/no-nodejs-modules": "off",
        "eslint/no-restricted-imports": "off"
      }
    }
  ],
  "ignorePatterns": ["**/build/**", "**/node_modules/**", "**/*.d.ts"]
}
